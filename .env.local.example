# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
VITE_GOOGLE_MAPS_EMBED_API_KEY=tu-google-maps-embed-key

# Google AdSense (banner web, solo se muestra fuera de la app nativa Android
# y a usuarios no premium). Sin este valor, AdBanner no renderiza nada.
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Mercado Pago (frontend/server local)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx
APP_BASE_URL=http://localhost:5173
MP_WEBHOOK_KEY=tu-webhook-key-seguro

# Planes (si no defines IDs de plan, se usa auto_recurring por monto)
MP_PLAN_MONTHLY_ID=
MP_PLAN_ANNUAL_ID=
MP_MONTHLY_AMOUNT_ARS=9900
MP_ANNUAL_AMOUNT_ARS=99900
MP_MONTHLY_AMOUNT_USD=9.90
MP_ANNUAL_AMOUNT_USD=99.90

# Opcional: endpoint custom o sandbox API base
# MP_API_BASE_URL=https://api.mercadopago.com

# Pasarela USD (futuro: usuarios no-AR)
USD_GATEWAY_PROVIDER=stripe
USD_GATEWAY_CREATE_SESSION_URL=
USD_GATEWAY_API_KEY=

# Opcional: para desarrollo local con Supabase CLI
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=eyJhbGc...

# Script local "npm run check-ml-prices" (chequeo de estado y precio de
# productos ML — se corre a mano desde tu PC, no desde GitHub Actions,
# porque ML bloquea las IPs de datacenter/cloud).
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# Opcional: para que ese mismo script te mande un email de resumen (Resend)
RESEND_API_KEY=
EMAIL_FROM=AiPetFriendly <notificaciones@tu-dominio.com>
ADMIN_NOTIFICATION_EMAIL=tu-email@dominio.com

# Opcional: respaldo de precio via API oficial de ML cuando el scraping de la
# ficha no puede leerlo (mismos valores que ya tenes en GitHub Secrets para
# sync-ml-products.mjs)
ML_REFRESH_TOKEN=
ML_APP_ID=
ML_APP_SECRET=

