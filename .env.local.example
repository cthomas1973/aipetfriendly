# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
VITE_GOOGLE_MAPS_EMBED_API_KEY=tu-google-maps-embed-key

# Mercado Pago (frontend/server local)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx
APP_BASE_URL=http://localhost:5173
MP_WEBHOOK_KEY=tu-webhook-key-seguro

# Planes (si no defines IDs de plan, se usa auto_recurring por monto)
MP_PLAN_MONTHLY_ID=
MP_PLAN_ANNUAL_ID=
MP_MONTHLY_AMOUNT_ARS=9900
MP_ANNUAL_AMOUNT_ARS=99900
MP_MONTHLY_AMOUNT_USD=9.90
MP_ANNUAL_AMOUNT_USD=99.90

# Opcional: endpoint custom o sandbox API base
# MP_API_BASE_URL=https://api.mercadopago.com

# Pasarela USD (futuro: usuarios no-AR)
USD_GATEWAY_PROVIDER=stripe
USD_GATEWAY_CREATE_SESSION_URL=
USD_GATEWAY_API_KEY=

# Opcional: para desarrollo local con Supabase CLI
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=eyJhbGc...
